# Nextcloud image tag (see hub.docker.com/_/nextcloud)
NEXTCLOUD_IMAGE_TAG=stable

# Host port for Nextcloud
NEXTCLOUD_PORT=8080

# Admin credentials (first-run auto-setup)
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=admin

# MariaDB
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=nextcloud

# Xdebug: off | develop | debug | develop,debug | coverage
XDEBUG_MODE=develop,debug
